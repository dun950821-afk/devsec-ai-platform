<idea-plugin>
    <id>com.guoshun.devsecai</id>
    <name>DevSecAI - Security Assistant</name>
    <vendor email="devsecai@guoshun.com" url="https://devsecai.guoshun.com">Guoshun Security</vendor>
    <description><![CDATA[
    <h3>DevSecAI Security Assistant</h3>
    <p>Security detection IDE plugin for developers, real-time security risk detection during coding.</p>
    <ul>
      <li><b>SAST Static Code Analysis</b>: Real-time detection of security vulnerabilities in Java/Kotlin code</li>
      <li><b>SCA Software Composition Analysis</b>: Detect known vulnerabilities in project dependencies</li>
      <li><b>Secrets Detection</b>: Prevent hardcoded keys, passwords and other leaks</li>
      <li><b>AI Analysis</b>: Provide vulnerability explanation and fix suggestions</li>
      <li><b>Git Commit Check</b>: Block commits with high-severity vulnerabilities</li>
    </ul>
    ]]></description>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                parentId="tools"
                instance="com.guoshun.devsecai.config.DevSecAISettingsConfigurable"
                id="com.guoshun.devsecai.config.DevSecAISettingsConfigurable"
                displayName="DevSecAI Security"/>

        <applicationService
                serviceImplementation="com.guoshun.devsecai.config.DevSecAISettings"/>

        <projectService
                serviceImplementation="com.guoshun.devsecai.service.PolicyService"/>
        <projectService
                serviceImplementation="com.guoshun.devsecai.service.FindingCollector"/>
        <projectService
                serviceImplementation="com.guoshun.devsecai.service.HeartbeatService"/>

        <postStartupActivity
                implementation="com.guoshun.devsecai.service.ProjectStartupListener"/>

        <localInspection
                language="JAVA"
                displayName="DevSecAI Security Inspection"
                groupName="DevSecAI"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="com.guoshun.devsecai.inspection.SecurityInspectionTool"/>

        <localInspection
                language="JAVA"
                displayName="DevSecAI Secrets Detection"
                groupName="DevSecAI"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="com.guoshun.devsecai.inspection.SecretsInspectionTool"/>

        <toolWindow
                id="DevSecAI"
                secondary="true"
                anchor="bottom"
                factoryClass="com.guoshun.devsecai.ui.DevSecAIToolWindowFactory"/>

        <checkinHandlerFactory
                implementation="com.guoshun.devsecai.action.SecurityCheckinHandlerFactory"/>
    </extensions>

    <actions>
        <action id="DevSecAI.ManualScan"
                class="com.guoshun.devsecai.action.ManualScanAction"
                text="DevSecAI Security Scan"
                description="Run security scan on current project">
            <add-to-group group-id="AnalyzeActions" anchor="last"/>
        </action>
        <action id="DevSecAI.UploadFindings"
                class="com.guoshun.devsecai.action.UploadFindingsAction"
                text="Upload Findings"
                description="Upload detection results to management platform">
            <add-to-group group-id="AnalyzeActions" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
