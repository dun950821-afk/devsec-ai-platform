<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DevSecAI - 智能安全开发平台</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f7fa}
    .hidden{display:none!important}

    /* 登录页 */
    .login-container{display:flex;min-height:100vh}
    .login-left{flex:1;background:linear-gradient(135deg,#667eea,#764ba2);padding:60px;color:#fff;display:flex;flex-direction:column;justify-content:center}
    .brand{display:flex;align-items:center;gap:16px;margin-bottom:20px}
    .logo{width:60px;height:60px;background:#fff;color:#667eea;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:700}
    .brand h1{font-size:36px;font-weight:600}
    .slogan{font-size:18px;opacity:.9;margin-bottom:40px}
    .features{display:grid;grid-template-columns:1fr 1fr;gap:16px}
    .feature-item{background:rgba(255,255,255,.1);padding:16px;border-radius:8px;font-size:14px}
    .login-right{width:480px;background:#fff;padding:60px;display:flex;flex-direction:column;justify-content:center}
    .login-right h2{font-size:28px;color:#333;margin-bottom:8px}
    .subtitle{color:#666;margin-bottom:40px}
    .form-group{margin-bottom:20px}
    .form-group label{display:block;margin-bottom:8px;color:#333;font-weight:500;font-size:14px}
    .form-group input,.form-group select,.form-group textarea{width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:8px;font-size:14px;font-family:inherit;transition:border .2s}
    .form-group input:focus,.form-group select:focus,.form-group textarea:focus{outline:none;border-color:#667eea}
    .form-group textarea{resize:vertical;min-height:72px}
    .form-group .hint{font-size:12px;color:#999;margin-top:4px}
    .error-box,.success-box{padding:10px 14px;border-radius:6px;margin-bottom:16px;font-size:14px;display:none}
    .error-box{color:#c62828;background:#ffebee}
    .success-box{color:#2e7d32;background:#e8f5e9}
    .login-btn{width:100%;padding:14px;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border:none;border-radius:8px;font-size:16px;font-weight:500;cursor:pointer}
    .login-btn:hover:not(:disabled){opacity:.9}
    .login-btn:disabled{opacity:.6;cursor:not-allowed}
    .footer-text{margin-top:40px;text-align:center;color:#999;font-size:12px}

    /* 主布局 */
    .main-layout{display:flex;min-height:100vh}
    .sidebar{width:220px;background:#1e1e2e;color:#fff;display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100}
    .sidebar-header{padding:20px;border-bottom:1px solid rgba(255,255,255,.08)}
    .sidebar-logo{display:flex;align-items:center;gap:12px}
    .sidebar-logo .logo-sm{width:36px;height:36px;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px}
    .sidebar-logo span{font-size:16px;font-weight:600}
    .menu{flex:1;padding:12px 0;overflow-y:auto}
    .menu-section{margin-bottom:6px}
    .menu-title{padding:8px 20px;font-size:11px;color:#555;text-transform:uppercase;letter-spacing:1px}
    .menu-item{display:flex;align-items:center;gap:12px;padding:10px 20px;color:#888;cursor:pointer;font-size:14px;transition:all .15s}
    .menu-item:hover{background:rgba(255,255,255,.04);color:#ccc}
    .menu-item.active{background:rgba(102,126,234,.15);color:#667eea;border-right:3px solid #667eea}
    .menu-item .icon{width:20px;text-align:center;font-size:15px}
    .menu-item .badge{margin-left:auto;background:#e74c3c;color:#fff;padding:2px 7px;border-radius:10px;font-size:11px}

    /* 内容区 */
    .main-content{flex:1;margin-left:220px;display:flex;flex-direction:column}
    .header{background:#fff;padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #eee;position:sticky;top:0;z-index:50}
    .header-left{display:flex;align-items:center;gap:12px}
    .header-title{font-size:16px;font-weight:600;color:#333}
    .header-right{display:flex;align-items:center;gap:16px}
    .user-info{display:flex;align-items:center;gap:8px;color:#666;font-size:14px}
    .user-avatar{width:32px;height:32px;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px;font-weight:700}
    .content{padding:24px;flex:1}

    /* 按钮 */
    .btn{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:14px;transition:all .15s;display:inline-flex;align-items:center;gap:6px}
    .btn-default{background:#f0f0f0;color:#666}
    .btn-default:hover{background:#e0e0e0}
    .btn-primary{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff}
    .btn-primary:hover{opacity:.9}
    .btn-danger{background:#e74c3c;color:#fff}
    .btn-danger:hover{opacity:.9}
    .btn-success{background:#27ae60;color:#fff}
    .btn-sm{padding:4px 10px;font-size:12px}
    .btn-xs{padding:2px 8px;font-size:11px}

    /* 卡片 */
    .card{background:#fff;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,.06);overflow:hidden}
    .card-header{padding:16px 20px;border-bottom:1px solid #f0f0f0;display:flex;justify-content:space-between;align-items:center}
    .card-title{font-size:15px;font-weight:600;color:#333}
    .card-body{padding:20px}

    /* 统计卡片 */
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
    .stat-card{background:#fff;padding:20px;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,.06)}
    .stat-card .stat-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:12px}
    .stat-card .stat-value{font-size:28px;font-weight:700;color:#333;margin-bottom:2px}
    .stat-card .stat-label{font-size:13px;color:#999}
    .stat-card.blue .stat-icon{background:rgba(102,126,234,.1);color:#667eea}
    .stat-card.green .stat-icon{background:rgba(39,174,96,.1);color:#27ae60}
    .stat-card.orange .stat-icon{background:rgba(230,126,34,.1);color:#e67e22}
    .stat-card.red .stat-icon{background:rgba(231,76,60,.1);color:#e74c3c}
    .stat-card.purple .stat-icon{background:rgba(155,89,182,.1);color:#9b59b6}

    /* 页面头部 */
    .page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
    .page-title{font-size:18px;font-weight:600;color:#333}

    /* 表格 */
    .table{width:100%;border-collapse:collapse}
    .table th{background:#fafbfc;padding:12px 14px;text-align:left;font-weight:500;color:#666;font-size:13px;border-bottom:1px solid #eee}
    .table td{padding:12px 14px;color:#333;font-size:13px;border-bottom:1px solid #f5f5f5;vertical-align:middle}
    .table tr:hover td{background:#fafbfc}
    .table .actions{display:flex;gap:6px;flex-wrap:wrap}

    /* 标签 */
    .tag{display:inline-block;padding:3px 8px;border-radius:4px;font-size:12px;font-weight:500;white-space:nowrap}
    .tag-success{background:#e8f5e9;color:#2e7d32}
    .tag-warning{background:#fff3e0;color:#ef6c00}
    .tag-danger{background:#ffebee;color:#c62828}
    .tag-info{background:#e3f2fd;color:#1565c0}
    .tag-default{background:#f5f5f5;color:#666}
    .tag-purple{background:#f3e5f5;color:#7b1fa2}
    .tag-critical{background:#fce4ec;color:#880e4f}

    /* 搜索栏 */
    .search-bar{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;align-items:center}
    .search-bar input,.search-bar select{padding:8px 12px;border:1px solid #ddd;border-radius:6px;font-size:13px}
    .search-bar input:focus,.search-bar select:focus{border-color:#667eea;outline:none}
    .search-bar input{flex:1;min-width:180px}

    /* 模态框 */
    .modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.45);display:flex;align-items:center;justify-content:center;z-index:1000}
    .modal{background:#fff;border-radius:12px;width:92%;max-width:560px;max-height:85vh;overflow:auto}
    .modal-header{padding:18px 24px;border-bottom:1px solid #eee;display:flex;justify-content:space-between;align-items:center}
    .modal-header h3{font-size:17px;font-weight:600;color:#333}
    .modal-close{width:30px;height:30px;border:none;background:none;cursor:pointer;font-size:20px;color:#999;border-radius:4px}
    .modal-close:hover{background:#f5f5f5}
    .modal-body{padding:20px 24px}
    .modal-footer{padding:14px 24px;border-top:1px solid #eee;display:flex;justify-content:flex-end;gap:10px}

    /* 仪表盘网格 */
    .dashboard-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px}
    .risk-bar{display:flex;align-items:center;gap:10px;margin-bottom:8px}
    .risk-bar .label{width:60px;font-size:13px;color:#666;text-align:right}
    .risk-bar .bar{flex:1;height:20px;background:#f0f0f0;border-radius:4px;overflow:hidden;position:relative}
    .risk-bar .bar-fill{height:100%;border-radius:4px;transition:width .5s}
    .risk-bar .count{width:30px;font-size:13px;color:#333;font-weight:600}

    /* 详情展开行 */
    .detail-row td{background:#fafbfc;padding:16px 20px}
    .detail-section{margin-bottom:12px}
    .detail-section h4{font-size:13px;color:#666;margin-bottom:6px;font-weight:500}
    .detail-section p{font-size:13px;color:#333;line-height:1.6;white-space:pre-wrap}

    /* 空状态 */
    .empty-state{text-align:center;padding:50px 20px;color:#bbb}
    .empty-state .icon{font-size:40px;margin-bottom:12px}

    /* Toggle 开关 */
    .toggle{position:relative;width:40px;height:22px;cursor:pointer}
    .toggle input{opacity:0;width:0;height:0}
    .toggle .slider{position:absolute;top:0;left:0;right:0;bottom:0;background:#ccc;border-radius:22px;transition:.2s}
    .toggle .slider:before{content:"";position:absolute;height:16px;width:16px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.2s}
    .toggle input:checked+.slider{background:#667eea}
    .toggle input:checked+.slider:before{transform:translateX(18px)}

    /* 多选标签组 */
    .tag-group{display:flex;flex-wrap:wrap;gap:6px}
    .tag-check{padding:5px 12px;border:1px solid #ddd;border-radius:6px;font-size:13px;cursor:pointer;transition:all .15s;user-select:none}
    .tag-check.selected{background:#667eea;color:#fff;border-color:#667eea}
    .tag-check:hover{border-color:#667eea}

    /* 配置项 */
    .config-section{margin-bottom:20px}
    .config-section h3{font-size:15px;font-weight:600;color:#333;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #eee}
    .config-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
    .config-item{padding:14px;background:#fafbfc;border-radius:8px;border:1px solid #eee}
    .config-item label{display:block;font-size:13px;color:#666;margin-bottom:6px}
    .config-item .value{font-size:14px;color:#333;font-weight:500}
  </style>
</head>
<body>

<!-- ========== 登录页 ========== -->
<div id="loginPage" class="login-container">
  <div class="login-left">
    <div class="brand"><div class="logo">DS</div><h1>DevSecAI</h1></div>
    <p class="slogan">智能安全开发平台</p>
    <div class="features">
      <div class="feature-item">SCA 组件分析</div>
      <div class="feature-item">SAST 代码扫描</div>
      <div class="feature-item">Secrets 密钥检测</div>
      <div class="feature-item">AI 智能修复</div>
    </div>
  </div>
  <div class="login-right">
    <h2>用户登录</h2>
    <p class="subtitle">欢迎使用 DevSecAI 智能安全开发平台</p>
    <form id="loginForm">
      <div class="form-group"><label>用户名</label><input type="text" id="username" placeholder="请输入用户名" value="admin"></div>
      <div class="form-group"><label>密码</label><input type="password" id="password" placeholder="请输入密码" value="admin123"></div>
      <div class="error-box" id="errorMsg"></div>
      <div class="success-box" id="successMsg"></div>
      <button type="submit" class="login-btn" id="loginBtn">登 录</button>
    </form>
    <p class="footer-text">DevSecAI v1.0.0</p>
  </div>
</div>

<!-- ========== 主应用 ========== -->
<div id="app" class="main-layout hidden">
  <aside class="sidebar">
    <div class="sidebar-header"><div class="sidebar-logo"><div class="logo-sm">DS</div><span>DevSecAI</span></div></div>
    <nav class="menu">
      <div class="menu-section">
        <div class="menu-title">概览</div>
        <div class="menu-item active" data-page="dashboard" onclick="showPage('dashboard')"><span class="icon">📊</span><span>工作台</span></div>
      </div>
      <div class="menu-section">
        <div class="menu-title">安全管理</div>
        <div class="menu-item" data-page="plugin" onclick="showPage('plugin')"><span class="icon">🔌</span><span>插件管理</span></div>
        <div class="menu-item" data-page="project" onclick="showPage('project')"><span class="icon">📁</span><span>项目管理</span></div>
        <div class="menu-item" data-page="policy" onclick="showPage('policy')"><span class="icon">🛡️</span><span>检测策略</span></div>
        <div class="menu-item" data-page="rule" onclick="showPage('rule')"><span class="icon">📋</span><span>规则管理</span></div>
        <div class="menu-item" data-page="result" onclick="showPage('result')"><span class="icon">🔍</span><span>检测结果</span></div>
      </div>
      <div class="menu-section">
        <div class="menu-title">系统</div>
        <div class="menu-item" data-page="skill" onclick="showPage('skill')"><span class="icon">🤖</span><span>AI Skill</span></div>
        <div class="menu-item" data-page="user" onclick="showPage('user')"><span class="icon">👥</span><span>用户管理</span></div>
        <div class="menu-item" data-page="audit" onclick="showPage('audit')"><span class="icon">📜</span><span>审计日志</span></div>
        <div class="menu-item" data-page="settings" onclick="showPage('settings')"><span class="icon">⚙️</span><span>系统设置</span></div>
      </div>
    </nav>
  </aside>

  <div class="main-content">
    <header class="header">
      <div class="header-left"><span class="header-title" id="pageTitle">工作台</span></div>
      <div class="header-right">
        <div class="user-info"><div class="user-avatar" id="userAvatar">A</div><span id="userName">管理员</span></div>
        <button class="btn btn-default" onclick="handleLogout()">退出</button>
      </div>
    </header>
    <div class="content">

      <!-- ===== 工作台 ===== -->
      <div id="page-dashboard" class="page-content">
        <div class="stats-grid">
          <div class="stat-card blue"><div class="stat-icon">📁</div><div class="stat-value" id="statProjects">-</div><div class="stat-label">项目总数</div></div>
          <div class="stat-card green"><div class="stat-icon">✅</div><div class="stat-value" id="statRunning">-</div><div class="stat-label">运行中任务</div></div>
          <div class="stat-card orange"><div class="stat-icon">⚠️</div><div class="stat-value" id="statPending">-</div><div class="stat-label">待处理问题</div></div>
          <div class="stat-card purple"><div class="stat-icon">🔌</div><div class="stat-value" id="statPlugins">-</div><div class="stat-label">活跃插件</div></div>
        </div>
        <div class="dashboard-grid">
          <div class="card">
            <div class="card-header"><span class="card-title">风险等级分布</span></div>
            <div class="card-body" id="riskDistribution">
              <div class="risk-bar"><span class="label">严重</span><div class="bar"><div class="bar-fill" style="width:10%;background:#880e4f"></div></div><span class="count" id="riskCritical">0</span></div>
              <div class="risk-bar"><span class="label">高危</span><div class="bar"><div class="bar-fill" style="width:20%;background:#c62828"></div></div><span class="count" id="riskHigh">0</span></div>
              <div class="risk-bar"><span class="label">中危</span><div class="bar"><div class="bar-fill" style="width:35%;background:#ef6c00"></div></div><span class="count" id="riskMedium">0</span></div>
              <div class="risk-bar"><span class="label">低危</span><div class="bar"><div class="bar-fill" style="width:25%;background:#1565c0"></div></div><span class="count" id="riskLow">0</span></div>
              <div class="risk-bar"><span class="label">提示</span><div class="bar"><div class="bar-fill" style="width:10%;background:#999"></div></div><span class="count" id="riskInfo">0</span></div>
            </div>
          </div>
          <div class="card">
            <div class="card-header"><span class="card-title">插件状态概览</span></div>
            <div class="card-body" id="pluginOverview"><p style="color:#bbb">加载中...</p></div>
          </div>
        </div>
        <div class="card" style="margin-bottom:24px">
          <div class="card-header"><span class="card-title">最近检测结果</span><button class="btn btn-sm btn-default" onclick="showPage('result')">查看全部</button></div>
          <table class="table"><thead><tr><th>项目</th><th>检测类型</th><th>问题数</th><th>严重性</th><th>状态</th><th>时间</th></tr></thead><tbody id="dashboardResults"></tbody></table>
        </div>
      </div>

      <!-- ===== 插件管理 ===== -->
      <div id="page-plugin" class="page-content hidden">
        <div class="page-header"><span class="page-title">插件管理</span><button class="btn btn-primary" onclick="showPluginModal()">+ 添加插件</button></div>
        <div class="search-bar">
          <input type="text" id="pluginSearch" placeholder="搜索插件名称..." oninput="loadPlugins()">
          <select id="pluginCategoryFilter" onchange="loadPlugins()"><option value="">全部类别</option><option value="code_scanner">SAST代码扫描</option><option value="dependency_check">SCA组件分析</option><option value="secret_detection">Secrets密钥检测</option><option value="baseline_check">基线检查</option><option value="ai_analysis">AI分析</option></select>
          <select id="pluginStatusFilter" onchange="loadPlugins()"><option value="">全部状态</option><option value="ONLINE">在线</option><option value="OFFLINE">离线</option><option value="ERROR">异常</option><option value="DISABLED">已禁用</option></select>
        </div>
        <div class="card"><table class="table"><thead><tr><th>ID</th><th>名称</th><th>版本</th><th>类别</th><th>状态</th><th>心跳</th><th>操作</th></tr></thead><tbody id="pluginTable"></tbody></table></div>
      </div>

      <!-- ===== 项目管理 ===== -->
      <div id="page-project" class="page-content hidden">
        <div class="page-header"><span class="page-title">项目管理</span><button class="btn btn-primary" onclick="showProjectModal()">+ 添加项目</button></div>
        <div class="search-bar">
          <input type="text" id="projectSearch" placeholder="搜索项目名称..." oninput="loadProjects()">
          <select id="projectStatusFilter" onchange="loadProjects()"><option value="">全部状态</option><option value="1">启用</option><option value="0">禁用</option></select>
        </div>
        <div class="card"><table class="table"><thead><tr><th>ID</th><th>项目代码</th><th>名称</th><th>仓库URL</th><th>分支</th><th>策略</th><th>扫描</th><th>状态</th><th>操作</th></tr></thead><tbody id="projectTable"></tbody></table></div>
      </div>

      <!-- ===== 策略管理 ===== -->
      <div id="page-policy" class="page-content hidden">
        <div class="page-header"><span class="page-title">检测策略</span><button class="btn btn-primary" onclick="showPolicyModal()">+ 添加策略</button></div>
        <div class="search-bar">
          <input type="text" id="policySearch" placeholder="搜索策略名称..." oninput="loadPolicies()">
          <select id="policyScanTypeFilter" onchange="loadPolicies()"><option value="">全部扫描类型</option><option value="REALTIME">实时扫描</option><option value="SCHEDULED">定时扫描</option><option value="MANUAL">手动扫描</option></select>
        </div>
        <div class="card"><table class="table"><thead><tr><th>ID</th><th>名称</th><th>扫描类型</th><th>Cron</th><th>默认</th><th>状态</th><th>绑定规则</th><th>绑定插件</th><th>操作</th></tr></thead><tbody id="policyTable"></tbody></table></div>
      </div>

      <!-- ===== 规则管理 ===== -->
      <div id="page-rule" class="page-content hidden">
        <div class="page-header"><span class="page-title">规则管理</span><button class="btn btn-primary" onclick="showRuleModal()">+ 添加规则</button></div>
        <div class="search-bar">
          <input type="text" id="ruleSearch" placeholder="搜索规则名称..." oninput="loadRules()">
          <select id="ruleSeverityFilter" onchange="loadRules()"><option value="">全部严重性</option><option value="CRITICAL">严重</option><option value="HIGH">高危</option><option value="MEDIUM">中危</option><option value="LOW">低危</option><option value="INFO">提示</option></select>
          <select id="ruleCategoryFilter" onchange="loadRules()"><option value="">全部类别</option><option value="code_quality">代码质量</option><option value="security">安全漏洞</option><option value="best_practice">最佳实践</option></select>
        </div>
        <div class="card"><table class="table"><thead><tr><th>ID</th><th>名称</th><th>Key</th><th>严重性</th><th>类别</th><th>检测模式</th><th>状态</th><th>操作</th></tr></thead><tbody id="ruleTable"></tbody></table></div>
      </div>

      <!-- ===== 检测结果 ===== -->
      <div id="page-result" class="page-content hidden">
        <div class="page-header"><span class="page-title">检测结果</span></div>
        <div class="stats-grid" style="grid-template-columns:repeat(5,1fr)">
          <div class="stat-card red"><div class="stat-icon">🔴</div><div class="stat-value" id="resCritical">0</div><div class="stat-label">严重</div></div>
          <div class="stat-card orange"><div class="stat-icon">🟠</div><div class="stat-value" id="resHigh">0</div><div class="stat-label">高危</div></div>
          <div class="stat-card blue"><div class="stat-icon">🟡</div><div class="stat-value" id="resMedium">0</div><div class="stat-label">中危</div></div>
          <div class="stat-card green"><div class="stat-icon">🔵</div><div class="stat-value" id="resLow">0</div><div class="stat-label">低危</div></div>
          <div class="stat-card purple"><div class="stat-icon">⚪</div><div class="stat-value" id="resInfo">0</div><div class="stat-label">提示</div></div>
        </div>
        <div class="search-bar">
          <input type="text" id="resultSearch" placeholder="搜索项目名称..." oninput="loadResults()">
          <select id="resultStatusFilter" onchange="loadResults()"><option value="">全部状态</option><option value="PENDING">待确认</option><option value="CONFIRMED">已确认</option><option value="FIXED">已修复</option><option value="IGNORED">已忽略</option><option value="FALSE_POSITIVE">误报</option></select>
          <select id="resultSeverityFilter" onchange="loadResults()"><option value="">全部严重性</option><option value="CRITICAL">严重</option><option value="HIGH">高危</option><option value="MEDIUM">中危</option><option value="LOW">低危</option><option value="INFO">提示</option></select>
        </div>
        <div class="card"><table class="table"><thead><tr><th>ID</th><th>项目</th><th>规则</th><th>文件</th><th>行号</th><th>严重性</th><th>状态</th><th>时间</th><th>操作</th></tr></thead><tbody id="resultTable"></tbody></table></div>
      </div>

      <!-- ===== AI Skill ===== -->
      <div id="page-skill" class="page-content hidden">
        <div class="page-header"><span class="page-title">AI Skill</span><button class="btn btn-primary" onclick="showSkillModal()">+ 添加Skill</button></div>
        <div class="search-bar">
          <input type="text" id="skillSearch" placeholder="搜索名称..." oninput="loadSkills()">
          <select id="skillTypeFilter" onchange="loadSkills()"><option value="">全部类型</option><option value="analyzer">分析器</option><option value="fixer">修复器</option><option value="reviewer">审查器</option></select>
        </div>
        <div class="card"><table class="table"><thead><tr><th>ID</th><th>名称</th><th>类型</th><th>Provider</th><th>模型</th><th>描述</th><th>状态</th><th>操作</th></tr></thead><tbody id="skillTable"></tbody></table></div>
      </div>

      <!-- ===== 用户管理 ===== -->
      <div id="page-user" class="page-content hidden">
        <div class="page-header"><span class="page-title">用户管理</span><button class="btn btn-primary" onclick="showUserModal()">+ 添加用户</button></div>
        <div class="search-bar">
          <input type="text" id="userSearch" placeholder="搜索用户名..." oninput="loadUsers()">
          <select id="userRoleFilter" onchange="loadUsers()"><option value="">全部角色</option><option value="admin">管理员</option><option value="user">普通用户</option></select>
          <select id="userStatusFilter" onchange="loadUsers()"><option value="">全部状态</option><option value="1">启用</option><option value="0">禁用</option></select>
        </div>
        <div class="card"><table class="table"><thead><tr><th>ID</th><th>用户名</th><th>姓名</th><th>邮箱</th><th>角色</th><th>状态</th><th>最后登录</th><th>操作</th></tr></thead><tbody id="userTable"></tbody></table></div>
      </div>

      <!-- ===== 审计日志 ===== -->
      <div id="page-audit" class="page-content hidden">
        <div class="page-header"><span class="page-title">审计日志</span><button class="btn btn-default" onclick="exportAudit()">📥 导出</button></div>
        <div class="search-bar">
          <input type="text" id="auditSearch" placeholder="搜索操作用户..." oninput="loadAuditLogs()">
          <select id="auditTypeFilter" onchange="loadAuditLogs()"><option value="">全部类型</option><option value="LOGIN">登录</option><option value="LOGOUT">登出</option><option value="CREATE">创建</option><option value="UPDATE">更新</option><option value="DELETE">删除</option><option value="SCAN">扫描</option><option value="EXPORT">导出</option></select>
        </div>
        <div class="card"><table class="table"><thead><tr><th>ID</th><th>操作类型</th><th>操作内容</th><th>用户</th><th>IP</th><th>状态</th><th>时间</th></tr></thead><tbody id="auditTable"></tbody></table></div>
      </div>

      <!-- ===== 系统设置 ===== -->
      <div id="page-settings" class="page-content hidden">
        <div class="page-header"><span class="page-title">系统设置</span></div>
        <div class="card" style="margin-bottom:20px">
          <div class="card-header"><span class="card-title">AI 模型配置</span></div>
          <div class="card-body">
            <div class="config-grid">
              <div class="config-item"><label>默认Provider</label><select id="cfgProvider" onchange="saveSettings()" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"><option value="openai">OpenAI</option><option value="claude">Claude</option><option value="local">本地模型</option></select></div>
              <div class="config-item"><label>默认模型</label><input type="text" id="cfgModel" value="gpt-4" onchange="saveSettings()" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
              <div class="config-item"><label>API端点</label><input type="text" id="cfgEndpoint" value="https://api.openai.com/v1" onchange="saveSettings()" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
              <div class="config-item"><label>温度参数</label><input type="number" id="cfgTemp" value="0.7" step="0.1" min="0" max="2" onchange="saveSettings()" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
            </div>
          </div>
        </div>
        <div class="card" style="margin-bottom:20px">
          <div class="card-header"><span class="card-title">通知配置</span></div>
          <div class="card-body">
            <div class="config-grid">
              <div class="config-item"><label>邮件通知</label><label class="toggle"><input type="checkbox" id="cfgEmail" onchange="saveSettings()"><span class="slider"></span></label></div>
              <div class="config-item"><label>钉钉通知</label><label class="toggle"><input type="checkbox" id="cfgDingTalk" onchange="saveSettings()"><span class="slider"></span></label></div>
              <div class="config-item"><label>企业微信</label><label class="toggle"><input type="checkbox" id="cfgWeChat" onchange="saveSettings()"><span class="slider"></span></label></div>
              <div class="config-item"><label>Webhook</label><input type="text" id="cfgWebhook" placeholder="https://..." onchange="saveSettings()" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
            </div>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><span class="card-title">安全策略</span></div>
          <div class="card-body">
            <div class="config-grid">
              <div class="config-item"><label>会话超时(分钟)</label><input type="number" id="cfgSession" value="60" onchange="saveSettings()" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
              <div class="config-item"><label>最大登录尝试</label><input type="number" id="cfgMaxAttempt" value="5" onchange="saveSettings()" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
              <div class="config-item"><label>密码最小长度</label><input type="number" id="cfgPwdLen" value="8" onchange="saveSettings()" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
              <div class="config-item"><label>Token有效期(小时)</label><input type="number" id="cfgTokenTTL" value="24" onchange="saveSettings()" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ===== 模态框 ===== -->
<div id="modalOverlay" class="modal-overlay hidden">
  <div class="modal">
    <div class="modal-header"><h3 id="modalTitle">标题</h3><button class="modal-close" onclick="closeModal()">&times;</button></div>
    <div class="modal-body" id="modalBody"></div>
    <div class="modal-footer"><button class="btn btn-default" onclick="closeModal()">取消</button><button class="btn btn-primary" id="modalConfirmBtn" onclick="confirmModal()">确定</button></div>
  </div>
</div>

<!-- ===== 详情模态框 ===== -->
<div id="detailOverlay" class="modal-overlay hidden">
  <div class="modal" style="max-width:640px">
    <div class="modal-header"><h3 id="detailTitle">详情</h3><button class="modal-close" onclick="closeDetail()">&times;</button></div>
    <div class="modal-body" id="detailBody"></div>
  </div>
</div>

<script>
var token = localStorage.getItem('token') || '';
var userName = localStorage.getItem('userName') || '管理员';
var currentEditId = null;
var modalCallback = null;
var cacheData = { plugins: [], policies: [], rules: [] };

// ===== 工具函数 =====
function esc(s) { return s == null ? '' : String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function api(url, opts) {
  return fetch(url, { ...opts, headers: { 'Content-Type':'application/json', 'Authorization':'Bearer '+token, ...(opts&&opts.headers||{}) } }).then(function(r){ return r.json(); });
}
function sevTag(s) {
  var m = { CRITICAL:'tag-critical', HIGH:'tag-danger', MEDIUM:'tag-warning', LOW:'tag-info', INFO:'tag-default' };
  var t = { CRITICAL:'严重', HIGH:'高危', MEDIUM:'中危', LOW:'低危', INFO:'提示' };
  return '<span class="tag '+(m[s]||'tag-default')+'">'+(t[s]||s)+'</span>';
}
function statusTag(s) {
  var m = { ONLINE:'tag-success', OFFLINE:'tag-warning', ERROR:'tag-danger', DISABLED:'tag-default', PENDING:'tag-warning', CONFIRMED:'tag-info', FIXED:'tag-success', IGNORED:'tag-default', FALSE_POSITIVE:'tag-purple' };
  var t = { ONLINE:'在线', OFFLINE:'离线', ERROR:'异常', DISABLED:'已禁用', PENDING:'待确认', CONFIRMED:'已确认', FIXED:'已修复', IGNORED:'已忽略', FALSE_POSITIVE:'误报' };
  return '<span class="tag '+(m[s]||'tag-default')+'">'+(t[s]||s)+'</span>';
}
function catTag(c) {
  var m = { code_scanner:'tag-danger', dependency_check:'tag-info', secret_detection:'tag-warning', baseline_check:'tag-purple', ai_analysis:'tag-success' };
  var t = { code_scanner:'SAST', dependency_check:'SCA', secret_detection:'Secrets', baseline_check:'基线检查', ai_analysis:'AI分析' };
  return '<span class="tag '+(m[c]||'tag-default')+'">'+(t[c]||c)+'</span>';
}
function roleTag(r) {
  var m = { admin:'tag-danger', user:'tag-info' };
  var t = { admin:'管理员', user:'普通用户' };
  return '<span class="tag '+(m[r]||'tag-default')+'">'+(t[r]||r)+'</span>';
}
function scanTypeTag(t) {
  var m = { REALTIME:'tag-success', SCHEDULED:'tag-info', MANUAL:'tag-default' };
  var n = { REALTIME:'实时扫描', SCHEDULED:'定时扫描', MANUAL:'手动扫描' };
  return '<span class="tag '+(m[t]||'tag-default')+'">'+(n[t]||t)+'</span>';
}

// ===== 登录 =====
function handleLogin(e) {
  if(e) e.preventDefault();
  var u=document.getElementById('username').value, p=document.getElementById('password').value;
  var errEl=document.getElementById('errorMsg'), sucEl=document.getElementById('successMsg'), btn=document.getElementById('loginBtn');
  errEl.style.display='none'; sucEl.style.display='none';
  if(!u||!p){ errEl.textContent='请输入用户名和密码'; errEl.style.display='block'; return; }
  btn.disabled=true; btn.textContent='登录中...';
  fetch('/api/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:u,password:p})})
  .then(function(r){return r.json()}).then(function(d){
    if(d.code===200){ token=d.data.token; localStorage.setItem('token',token); localStorage.setItem('userName',d.data.userInfo.realName||u); userName=d.data.userInfo.realName||u; sucEl.textContent='登录成功！'; sucEl.style.display='block'; setTimeout(function(){showApp();loadDashboardData()},800); }
    else{ errEl.textContent=d.message||'登录失败'; errEl.style.display='block'; }
  }).catch(function(){ errEl.textContent='网络错误，请稍后重试'; errEl.style.display='block'; })
  .finally(function(){ btn.disabled=false; btn.textContent='登 录'; });
}
function handleLogout(){ api('/api/auth/logout',{method:'POST'}); token=''; localStorage.removeItem('token'); localStorage.removeItem('userName'); location.reload(); }
function showApp(){ document.getElementById('loginPage').classList.add('hidden'); document.getElementById('app').classList.remove('hidden'); document.getElementById('userName').textContent=userName; document.getElementById('userAvatar').textContent=userName.charAt(0).toUpperCase(); }

// ===== 页面路由 =====
function showPage(page) {
  document.querySelectorAll('.page-content').forEach(function(el){el.classList.add('hidden')});
  document.getElementById('page-'+page).classList.remove('hidden');
  document.querySelectorAll('.menu-item').forEach(function(el){el.classList.remove('active')});
  var mi=document.querySelector('.menu-item[data-page="'+page+'"]'); if(mi)mi.classList.add('active');
  var t={dashboard:'工作台',plugin:'插件管理',project:'项目管理',policy:'检测策略',rule:'规则管理',result:'检测结果',skill:'AI Skill',user:'用户管理',audit:'审计日志',settings:'系统设置'};
  document.getElementById('pageTitle').textContent=t[page]||'工作台';
  switch(page){ case'dashboard':loadDashboardData();break;case'plugin':loadPlugins();break;case'project':loadProjects();break;case'policy':loadPolicies();break;case'rule':loadRules();break;case'result':loadResults();break;case'skill':loadSkills();break;case'user':loadUsers();break;case'audit':loadAuditLogs();break;case'settings':loadSettings();break; }
}

// ===== 1.1 工作台 =====
function loadDashboardData(){
  api('/api/dashboard',{method:'GET'}).then(function(d){
    if(d.code===200){ var v=d.data; document.getElementById('statProjects').textContent=v.projectCount||0; document.getElementById('statRunning').textContent=v.runningTasks||0; document.getElementById('statPending').textContent=v.pendingIssues||0; document.getElementById('statPlugins').textContent=v.activePlugins||0; }
  });
  api('/api/result/list',{method:'GET'}).then(function(d){
    if(d.code===200){ var rs=d.data.records||[]; renderDashboardResults(rs); calcRiskDist(rs); }
  });
  api('/api/plugin/list',{method:'GET'}).then(function(d){
    if(d.code===200) renderPluginOverview(d.data.records||[]);
  });
}
function calcRiskDist(rs){
  var c={CRITICAL:0,HIGH:0,MEDIUM:0,LOW:0,INFO:0}; rs.forEach(function(r){c[r.severity]=(c[r.severity]||0)+1});
  var total=rs.length||1;
  document.getElementById('riskCritical').textContent=c.CRITICAL; document.getElementById('riskHigh').textContent=c.HIGH; document.getElementById('riskMedium').textContent=c.MEDIUM; document.getElementById('riskLow').textContent=c.LOW; document.getElementById('riskInfo').textContent=c.INFO;
  var bars=document.querySelectorAll('#riskDistribution .bar-fill');
  var vals=[c.CRITICAL,c.HIGH,c.MEDIUM,c.LOW,c.INFO];
  bars.forEach(function(b,i){b.style.width=Math.round(vals[i]/total*100)+'%'});
}
function renderPluginOverview(ps){
  var online=0,offline=0,err=0,disabled=0;
  ps.forEach(function(p){if(p.status==='ONLINE')online++;else if(p.status==='OFFLINE')offline++;else if(p.status==='ERROR')err++;else disabled++});
  document.getElementById('pluginOverview').innerHTML='<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px"><div style="text-align:center;padding:12px;background:#e8f5e9;border-radius:8px"><div style="font-size:24px;font-weight:700;color:#2e7d32">'+online+'</div><div style="font-size:13px;color:#666">在线</div></div><div style="text-align:center;padding:12px;background:#fff3e0;border-radius:8px"><div style="font-size:24px;font-weight:700;color:#ef6c00">'+offline+'</div><div style="font-size:13px;color:#666">离线</div></div><div style="text-align:center;padding:12px;background:#ffebee;border-radius:8px"><div style="font-size:24px;font-weight:700;color:#c62828">'+err+'</div><div style="font-size:13px;color:#666">异常</div></div><div style="text-align:center;padding:12px;background:#f5f5f5;border-radius:8px"><div style="font-size:24px;font-weight:700;color:#666">'+disabled+'</div><div style="font-size:13px;color:#666">已禁用</div></div></div>';
}
function renderDashboardResults(rs){
  var tb=document.getElementById('dashboardResults');
  if(!rs||!rs.length){tb.innerHTML='<tr><td colspan="6" class="empty-state">暂无数据</td></tr>';return;}
  tb.innerHTML=rs.slice(0,5).map(function(r){return '<tr><td>'+esc(r.projectName||'-')+'</td><td>'+esc(r.ruleName||'-')+'</td><td>'+(r.issueCount||0)+'</td><td>'+sevTag(r.severity)+'</td><td>'+statusTag(r.status)+'</td><td>'+(r.createTime||'-')+'</td></tr>';}).join('');
}

// ===== 2.1 插件管理 =====
function loadPlugins(){
  var s=document.getElementById('pluginSearch').value, c=document.getElementById('pluginCategoryFilter').value, st=document.getElementById('pluginStatusFilter').value;
  api('/api/plugin/list?name='+encodeURIComponent(s)+'&category='+c+'&status='+st,{method:'GET'}).then(function(d){
    if(d.code===200){cacheData.plugins=d.data.records||[];renderPluginTable(cacheData.plugins);}
  });
}
function renderPluginTable(ps){
  var tb=document.getElementById('pluginTable');
  if(!ps||!ps.length){tb.innerHTML='<tr><td colspan="7" class="empty-state"><div class="icon">🔌</div>暂无插件</td></tr>';return;}
  tb.innerHTML=ps.map(function(p){return '<tr><td>'+p.id+'</td><td>'+esc(p.name)+'</td><td>'+esc(p.version||'-')+'</td><td>'+catTag(p.category||'code_scanner')+'</td><td>'+statusTag(p.status||'OFFLINE')+'</td><td>'+(p.lastHeartbeat||'-')+'</td><td><div class="actions"><button class="btn btn-sm btn-default" onclick="editPlugin('+p.id+')">编辑</button><button class="btn btn-sm '+(p.status==='DISABLED'?'btn-primary':'btn-danger')+'" onclick="togglePlugin('+p.id+',\''+p.status+'\')">'+(p.status==='DISABLED'?'启用':'禁用')+'</button><button class="btn btn-sm btn-danger" onclick="delPlugin('+p.id+')">删除</button></div></td></tr>';}).join('');
}
function showPluginModal(id){
  currentEditId=id;
  document.getElementById('modalTitle').textContent=id?'编辑插件':'添加插件';
  var body='<div class="form-group"><label>插件名称</label><input type="text" id="mPluginName" placeholder="请输入插件名称"></div><div class="form-group"><label>版本</label><input type="text" id="mPluginVersion" placeholder="如 v1.0.0"></div><div class="form-group"><label>类别</label><select id="mPluginCategory"><option value="code_scanner">SAST代码扫描</option><option value="dependency_check">SCA组件分析</option><option value="secret_detection">Secrets密钥检测</option><option value="baseline_check">基线检查</option><option value="ai_analysis">AI分析</option></select></div><div class="form-group"><label>描述</label><textarea id="mPluginDesc" placeholder="请输入描述"></textarea></div><div class="form-group"><label>配置(JSON)</label><textarea id="mPluginConfig" placeholder=\'{"key":"value"}\' style="font-family:monospace"></textarea></div>';
  if(id){ api('/api/plugin/'+id,{method:'GET'}).then(function(d){ if(d.code===200){var p=d.data; fillPluginForm(p);} }); }
  else{ document.getElementById('modalBody').innerHTML=body; }
  document.getElementById('modalOverlay').classList.remove('hidden');
  modalCallback=savePlugin;
}
function fillPluginForm(p){ document.getElementById('mPluginName').value=p.name||''; document.getElementById('mPluginVersion').value=p.version||''; document.getElementById('mPluginCategory').value=p.category||'code_scanner'; document.getElementById('mPluginDesc').value=p.description||''; document.getElementById('mPluginConfig').value=p.config||''; }
function savePlugin(){
  var n=document.getElementById('mPluginName').value,v=document.getElementById('mPluginVersion').value,c=document.getElementById('mPluginCategory').value,d=document.getElementById('mPluginDesc').value,cfg=document.getElementById('mPluginConfig').value;
  if(!n){alert('请输入名称');return;}
  var m=currentEditId?'PUT':'POST', u=currentEditId?'/api/plugin/'+currentEditId:'/api/plugin';
  api(u,{method:m,body:JSON.stringify({name:n,version:v,category:c,description:d,config:cfg})}).then(function(d){if(d.code===200){closeModal();loadPlugins();}else alert(d.message||'保存失败');});
}
function editPlugin(id){ showPluginModal(id); }
function togglePlugin(id,st){ api('/api/plugin/'+id+'/status',{method:'PUT',body:JSON.stringify({status:st==='DISABLED'?'ONLINE':'DISABLED'})}).then(function(d){if(d.code===200)loadPlugins();else alert(d.message||'操作失败');}); }
function delPlugin(id){ if(!confirm('确定删除？'))return; api('/api/plugin/'+id,{method:'DELETE'}).then(function(d){if(d.code===200)loadPlugins();else alert(d.message||'删除失败');}); }

// ===== 2.2 项目管理 =====
function loadProjects(){
  var s=document.getElementById('projectSearch').value,st=document.getElementById('projectStatusFilter').value;
  api('/api/project/list?name='+encodeURIComponent(s)+'&status='+st,{method:'GET'}).then(function(d){if(d.code===200)renderProjectTable(d.data.records||[]);});
}
function renderProjectTable(ps){
  var tb=document.getElementById('projectTable');
  if(!ps||!ps.length){tb.innerHTML='<tr><td colspan="9" class="empty-state"><div class="icon">📁</div>暂无项目</td></tr>';return;}
  tb.innerHTML=ps.map(function(p){return '<tr><td>'+p.id+'</td><td><code>'+esc(p.code||'-')+'</code></td><td>'+esc(p.name)+'</td><td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+esc(p.repoUrl||'-')+'</td><td>'+esc(p.branch||'-')+'</td><td>'+(p.policyId?'<span class="tag tag-info">已绑定</span>':'<span class="tag tag-default">未绑定</span>')+'</td><td><label class="toggle"><input type="checkbox" '+(p.scanEnabled?'checked':'')+' onchange="toggleProjectScan('+p.id+',this.checked)"><span class="slider"></span></label></td><td>'+(p.status===1?'<span class="tag tag-success">启用</span>':'<span class="tag tag-default">禁用</span>')+'</td><td><div class="actions"><button class="btn btn-sm btn-default" onclick="editProject('+p.id+')">编辑</button><button class="btn btn-sm btn-danger" onclick="delProject('+p.id+')">删除</button></div></td></tr>';}).join('');
}
function showProjectModal(id){
  currentEditId=id; document.getElementById('modalTitle').textContent=id?'编辑项目':'添加项目';
  var body='<div class="form-group"><label>项目代码</label><input type="text" id="mProjCode" placeholder="如 user-service"><div class="hint">唯一标识，用于关联检测结果</div></div><div class="form-group"><label>项目名称</label><input type="text" id="mProjName" placeholder="请输入项目名称"></div><div class="form-group"><label>仓库URL</label><input type="text" id="mProjRepo" placeholder="https://github.com/xxx/xxx"></div><div class="form-group"><label>分支</label><input type="text" id="mProjBranch" value="main"></div><div class="form-group"><label>绑定策略</label><select id="mProjPolicy"><option value="">不绑定</option></select></div><div class="form-group"><label>描述</label><textarea id="mProjDesc" placeholder="请输入描述"></textarea></div>';
  document.getElementById('modalBody').innerHTML=body;
  loadPolicyOptions();
  if(id) api('/api/project/'+id,{method:'GET'}).then(function(d){if(d.code===200){var p=d.data;document.getElementById('mProjCode').value=p.code||'';document.getElementById('mProjName').value=p.name||'';document.getElementById('mProjRepo').value=p.repoUrl||'';document.getElementById('mProjBranch').value=p.branch||'main';document.getElementById('mProjDesc').value=p.description||'';setTimeout(function(){document.getElementById('mProjPolicy').value=p.policyId||'';},300);}});
  document.getElementById('modalOverlay').classList.remove('hidden'); modalCallback=saveProject;
}
function loadPolicyOptions(){
  api('/api/policy/list',{method:'GET'}).then(function(d){if(d.code===200){var sel=document.getElementById('mProjPolicy');(d.data.records||[]).forEach(function(p){var o=document.createElement('option');o.value=p.id;o.textContent=p.name;sel.appendChild(o);});}});
}
function saveProject(){
  var c=document.getElementById('mProjCode').value,n=document.getElementById('mProjName').value,r=document.getElementById('mProjRepo').value,b=document.getElementById('mProjBranch').value,pid=document.getElementById('mProjPolicy').value,d=document.getElementById('mProjDesc').value;
  if(!n){alert('请输入项目名称');return;}
  var m=currentEditId?'PUT':'POST',u=currentEditId?'/api/project/'+currentEditId:'/api/project';
  api(u,{method:m,body:JSON.stringify({code:c,name:n,repoUrl:r,branch:b,policyId:pid?parseInt(pid):null,description:d})}).then(function(d){if(d.code===200){closeModal();loadProjects();}else alert(d.message||'保存失败');});
}
function editProject(id){showProjectModal(id);}
function toggleProjectScan(id,en){api('/api/project/'+id,{method:'PUT',body:JSON.stringify({scanEnabled:en})}).then(function(d){if(d.code!==200)loadProjects();});}
function delProject(id){if(!confirm('确定删除？'))return;api('/api/project/'+id,{method:'DELETE'}).then(function(d){if(d.code===200)loadProjects();else alert(d.message||'删除失败');});}

// ===== 1.4 策略管理 =====
function loadPolicies(){
  var s=document.getElementById('policySearch').value,st=document.getElementById('policyScanTypeFilter').value;
  api('/api/policy/list?name='+encodeURIComponent(s)+'&scanType='+st,{method:'GET'}).then(function(d){if(d.code===200){cacheData.policies=d.data.records||[];renderPolicyTable(cacheData.policies);}});
}
function renderPolicyTable(ps){
  var tb=document.getElementById('policyTable');
  if(!ps||!ps.length){tb.innerHTML='<tr><td colspan="9" class="empty-state"><div class="icon">🛡️</div>暂无策略</td></tr>';return;}
  tb.innerHTML=ps.map(function(p){return '<tr><td>'+p.id+'</td><td>'+esc(p.name)+'</td><td>'+scanTypeTag(p.scanType||'MANUAL')+'</td><td><code>'+esc(p.cronExpression||'-')+'</code></td><td>'+(p.isDefault?'<span class="tag tag-success">默认</span>':'-')+'</td><td>'+(p.status===1?'<span class="tag tag-success">启用</span>':'<span class="tag tag-default">禁用</span>')+'</td><td>'+(p.ruleIds?'<span class="tag tag-info">'+p.ruleIds.split(',').length+'条</span>':'-')+'</td><td>'+(p.pluginIds?'<span class="tag tag-info">'+p.pluginIds.split(',').length+'个</span>':'-')+'</td><td><div class="actions"><button class="btn btn-sm btn-default" onclick="editPolicy('+p.id+')">编辑</button><button class="btn btn-sm btn-danger" onclick="delPolicy('+p.id+')">删除</button></div></td></tr>';}).join('');
}
function showPolicyModal(id){
  currentEditId=id; document.getElementById('modalTitle').textContent=id?'编辑策略':'添加策略';
  var body='<div class="form-group"><label>策略名称</label><input type="text" id="mPolicyName" placeholder="请输入策略名称"></div><div class="form-group"><label>扫描类型</label><select id="mPolicyScanType"><option value="REALTIME">实时扫描</option><option value="SCHEDULED">定时扫描</option><option value="MANUAL">手动扫描</option></select></div><div class="form-group" id="cronGroup"><label>Cron表达式</label><input type="text" id="mPolicyCron" placeholder="0 0 2 * * ?"><div class="hint">仅定时扫描需要，如: 0 0 2 * * ? (每天凌晨2点)</div></div><div class="form-group"><label>风险阈值</label><select id="mPolicyThreshold"><option value="LOW">低(所有问题)</option><option value="MEDIUM" selected>中(中危及以上)</option><option value="HIGH">高(高危及以上)</option><option value="CRITICAL">严重(仅严重)</option></select></div><div class="form-group"><label>阻断策略</label><select id="mPolicyBlock"><option value="NONE">不阻断</option><option value="WARN">仅告警</option><option value="BLOCK">阻断合并</option></select></div><div class="form-group"><label>绑定规则</label><div class="tag-group" id="mPolicyRules">加载中...</div></div><div class="form-group"><label>绑定插件</label><div class="tag-group" id="mPolicyPlugins">加载中...</div></div><div class="form-group"><label>设为默认策略</label><label class="toggle"><input type="checkbox" id="mPolicyDefault"><span class="slider"></span></label></div><div class="form-group"><label>描述</label><textarea id="mPolicyDesc" placeholder="请输入描述"></textarea></div>';
  document.getElementById('modalBody').innerHTML=body;
  loadRuleTags(); loadPluginTags();
  if(id) api('/api/policy/'+id,{method:'GET'}).then(function(d){if(d.code===200){var p=d.data;document.getElementById('mPolicyName').value=p.name||'';document.getElementById('mPolicyScanType').value=p.scanType||'MANUAL';document.getElementById('mPolicyCron').value=p.cronExpression||'';document.getElementById('mPolicyThreshold').value=p.riskThreshold||'MEDIUM';document.getElementById('mPolicyBlock').value=p.blockStrategy||'NONE';document.getElementById('mPolicyDefault').checked=!!p.isDefault;document.getElementById('mPolicyDesc').value=p.description||'';if(p.ruleIds)selectTags('mPolicyRules',p.ruleIds.split(','));if(p.pluginIds)selectTags('mPolicyPlugins',p.pluginIds.split(','));}});
  document.getElementById('modalOverlay').classList.remove('hidden'); modalCallback=savePolicy;
}
function loadRuleTags(){api('/api/rule/list',{method:'GET'}).then(function(d){if(d.code===200){var c=document.getElementById('mPolicyRules');c.innerHTML='';(d.data.records||[]).forEach(function(r){c.innerHTML+='<span class="tag-check" data-id="'+r.id+'" onclick="toggleTag(this)">'+esc(r.name)+'</span>';});}});}
function loadPluginTags(){api('/api/plugin/list',{method:'GET'}).then(function(d){if(d.code===200){var c=document.getElementById('mPolicyPlugins');c.innerHTML='';(d.data.records||[]).forEach(function(p){c.innerHTML+='<span class="tag-check" data-id="'+p.id+'" onclick="toggleTag(this)">'+esc(p.name)+'</span>';});}});}
function toggleTag(el){el.classList.toggle('selected');}
function selectTags(containerId,ids){document.querySelectorAll('#'+containerId+' .tag-check').forEach(function(el){if(ids.indexOf(el.dataset.id)>=0)el.classList.add('selected');});}
function getSelectedTags(containerId){return Array.from(document.querySelectorAll('#'+containerId+' .tag-check.selected')).map(function(el){return el.dataset.id;});}
function savePolicy(){
  var n=document.getElementById('mPolicyName').value,st=document.getElementById('mPolicyScanType').value,cr=document.getElementById('mPolicyCron').value,th=document.getElementById('mPolicyThreshold').value,bk=document.getElementById('mPolicyBlock').value,df=document.getElementById('mPolicyDefault').checked,d=document.getElementById('mPolicyDesc').value;
  var rids=getSelectedTags('mPolicyRules').join(','),pids=getSelectedTags('mPolicyPlugins').join(',');
  if(!n){alert('请输入策略名称');return;}
  var m=currentEditId?'PUT':'POST',u=currentEditId?'/api/policy/'+currentEditId:'/api/policy';
  api(u,{method:m,body:JSON.stringify({name:n,scanType:st,cronExpression:cr,riskThreshold:th,blockStrategy:bk,isDefault:df,ruleIds:rids,pluginIds:pids,description:d})}).then(function(d){if(d.code===200){closeModal();loadPolicies();}else alert(d.message||'保存失败');});
}
function editPolicy(id){showPolicyModal(id);}
function delPolicy(id){if(!confirm('确定删除？'))return;api('/api/policy/'+id,{method:'DELETE'}).then(function(d){if(d.code===200)loadPolicies();else alert(d.message||'删除失败');});}

// ===== 2.3 规则管理 =====
function loadRules(){
  var s=document.getElementById('ruleSearch').value,sv=document.getElementById('ruleSeverityFilter').value,c=document.getElementById('ruleCategoryFilter').value;
  api('/api/rule/list?name='+encodeURIComponent(s)+'&severity='+sv+'&category='+c,{method:'GET'}).then(function(d){if(d.code===200){cacheData.rules=d.data.records||[];renderRuleTable(cacheData.rules);}});
}
function renderRuleTable(rs){
  var tb=document.getElementById('ruleTable');
  if(!rs||!rs.length){tb.innerHTML='<tr><td colspan="8" class="empty-state"><div class="icon">📋</div>暂无规则</td></tr>';return;}
  tb.innerHTML=rs.map(function(r){return '<tr><td>'+r.id+'</td><td>'+esc(r.name)+'</td><td><code>'+esc(r.ruleKey||'-')+'</code></td><td>'+sevTag(r.severity)+'</td><td>'+(r.category==='security'?'<span class="tag tag-danger">安全漏洞</span>':r.category==='code_quality'?'<span class="tag tag-info">代码质量</span>':'<span class="tag tag-default">最佳实践</span>')+'</td><td>'+(r.pattern?'<span class="tag tag-purple">正则</span>':'<span class="tag tag-default">AST</span>')+'</td><td>'+(r.status===1?'<span class="tag tag-success">启用</span>':'<span class="tag tag-default">禁用</span>')+'</td><td><div class="actions"><button class="btn btn-sm btn-default" onclick="editRule('+r.id+')">编辑</button><button class="btn btn-sm btn-default" onclick="viewRuleDetail('+r.id+')">详情</button><button class="btn btn-sm btn-danger" onclick="delRule('+r.id+')">删除</button></div></td></tr>';}).join('');
}
function showRuleModal(id){
  currentEditId=id; document.getElementById('modalTitle').textContent=id?'编辑规则':'添加规则';
  var body='<div class="form-group"><label>规则名称</label><input type="text" id="mRuleName" placeholder="请输入规则名称"></div><div class="form-group"><label>规则Key</label><input type="text" id="mRuleKey" placeholder="如 S001"></div><div class="form-group"><label>严重性</label><select id="mRuleSeverity"><option value="CRITICAL">严重</option><option value="HIGH">高危</option><option value="MEDIUM">中危</option><option value="LOW">低危</option><option value="INFO">提示</option></select></div><div class="form-group"><label>类别</label><select id="mRuleCategory"><option value="security">安全漏洞</option><option value="code_quality">代码质量</option><option value="best_practice">最佳实践</option></select></div><div class="form-group"><label>检测模式</label><select id="mRuleMode"><option value="AST">AST语法分析</option><option value="REGEX">正则匹配</option></select></div><div class="form-group"><label>正则Pattern</label><textarea id="mRulePattern" placeholder="正则表达式(选填)" style="font-family:monospace"></textarea></div><div class="form-group"><label>修复建议</label><textarea id="mRuleSolution" placeholder="请输入修复建议"></textarea></div><div class="form-group"><label>描述</label><textarea id="mRuleDesc" placeholder="请输入描述"></textarea></div>';
  document.getElementById('modalBody').innerHTML=body;
  if(id) api('/api/rule/'+id,{method:'GET'}).then(function(d){if(d.code===200){var r=d.data;document.getElementById('mRuleName').value=r.name||'';document.getElementById('mRuleKey').value=r.ruleKey||'';document.getElementById('mRuleSeverity').value=r.severity||'MEDIUM';document.getElementById('mRuleCategory').value=r.category||'security';document.getElementById('mRulePattern').value=r.pattern||'';document.getElementById('mRuleSolution').value=r.solution||'';document.getElementById('mRuleDesc').value=r.description||'';}});
  document.getElementById('modalOverlay').classList.remove('hidden'); modalCallback=saveRule;
}
function saveRule(){
  var n=document.getElementById('mRuleName').value,k=document.getElementById('mRuleKey').value,sv=document.getElementById('mRuleSeverity').value,c=document.getElementById('mRuleCategory').value,p=document.getElementById('mRulePattern').value,so=document.getElementById('mRuleSolution').value,d=document.getElementById('mRuleDesc').value;
  if(!n||!k){alert('请输入名称和Key');return;}
  var m=currentEditId?'PUT':'POST',u=currentEditId?'/api/rule/'+currentEditId:'/api/rule';
  api(u,{method:m,body:JSON.stringify({name:n,ruleKey:k,severity:sv,category:c,pattern:p,solution:so,description:d})}).then(function(d){if(d.code===200){closeModal();loadRules();}else alert(d.message||'保存失败');});
}
function editRule(id){showRuleModal(id);}
function viewRuleDetail(id){api('/api/rule/'+id,{method:'GET'}).then(function(d){if(d.code===200){var r=d.data;document.getElementById('detailTitle').textContent='规则详情 - '+r.name;document.getElementById('detailBody').innerHTML='<div class="detail-section"><h4>基本信息</h4><p>Key: '+esc(r.ruleKey)+'\n严重性: '+(r.severity||'-')+'\n类别: '+(r.category||'-')+'</p></div><div class="detail-section"><h4>正则Pattern</h4><p><code>'+(esc(r.pattern)||'无')+'</code></p></div><div class="detail-section"><h4>修复建议</h4><p>'+(esc(r.solution)||'暂无修复建议')+'</p></div><div class="detail-section"><h4>描述</h4><p>'+(esc(r.description)||'-')+'</p></div>';document.getElementById('detailOverlay').classList.remove('hidden');}});}
function delRule(id){if(!confirm('确定删除？'))return;api('/api/rule/'+id,{method:'DELETE'}).then(function(d){if(d.code===200)loadRules();else alert(d.message||'删除失败');});}

// ===== 1.3 检测结果 =====
function loadResults(){
  var s=document.getElementById('resultSearch').value,st=document.getElementById('resultStatusFilter').value,sv=document.getElementById('resultSeverityFilter').value;
  api('/api/result/list?projectName='+encodeURIComponent(s)+'&status='+st+'&severity='+sv,{method:'GET'}).then(function(d){
    if(d.code===200){var rs=d.data.records||[];renderResultTable(rs);calcResultStats(rs);}
  });
}
function calcResultStats(rs){
  var c={CRITICAL:0,HIGH:0,MEDIUM:0,LOW:0,INFO:0}; rs.forEach(function(r){c[r.severity]=(c[r.severity]||0)+1});
  document.getElementById('resCritical').textContent=c.CRITICAL;document.getElementById('resHigh').textContent=c.HIGH;document.getElementById('resMedium').textContent=c.MEDIUM;document.getElementById('resLow').textContent=c.LOW;document.getElementById('resInfo').textContent=c.INFO;
}
function renderResultTable(rs){
  var tb=document.getElementById('resultTable');
  if(!rs||!rs.length){tb.innerHTML='<tr><td colspan="9" class="empty-state"><div class="icon">🔍</div>暂无结果</td></tr>';return;}
  tb.innerHTML=rs.map(function(r){return '<tr><td>'+r.id+'</td><td>'+esc(r.projectName||'-')+'</td><td>'+esc(r.ruleName||'-')+'</td><td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+esc(r.filePath||'')+'">'+esc(r.filePath||'-')+'</td><td>'+(r.lineNumber||'-')+'</td><td>'+sevTag(r.severity)+'</td><td>'+statusTag(r.status)+'</td><td>'+(r.createTime||'-')+'</td><td><div class="actions"><button class="btn btn-xs btn-default" onclick="viewResultDetail('+r.id+')">详情</button>'+(r.status==='PENDING'?'<button class="btn btn-xs btn-primary" onclick="changeResultStatus('+r.id+',\'CONFIRMED\')">确认</button>':'')+(r.status==='CONFIRMED'?'<button class="btn btn-xs btn-success" onclick="changeResultStatus('+r.id+',\'FIXED\')">修复</button>':'')+'<button class="btn btn-xs btn-default" onclick="changeResultStatus('+r.id+',\'IGNORED\')">忽略</button><button class="btn btn-xs btn-default" onclick="changeResultStatus('+r.id+',\'FALSE_POSITIVE\')">误报</button></div></td></tr>';}).join('');
}
function viewResultDetail(id){api('/api/result/'+id,{method:'GET'}).then(function(d){if(d.code===200){var r=d.data;document.getElementById('detailTitle').textContent='检测结果 #'+r.id;document.getElementById('detailBody').innerHTML='<div class="detail-section"><h4>基本信息</h4><p>项目: '+esc(r.projectName)+'\n规则: '+esc(r.ruleName)+'\n严重性: '+(r.severity||'-')+'\n状态: '+(r.status||'-')+'</p></div><div class="detail-section"><h4>文件位置</h4><p>'+esc(r.filePath)+' (行 '+(r.lineNumber||'-')+')</p></div><div class="detail-section"><h4>漏洞详情</h4><p>'+(esc(r.detail)||esc(r.description)||'暂无详情')+'</p></div><div class="detail-section"><h4>修复建议</h4><p>'+(esc(r.solution)||'暂无修复建议')+'</p></div>';document.getElementById('detailOverlay').classList.remove('hidden');}});}
function changeResultStatus(id,st){api('/api/result/'+id+'/status',{method:'PUT',body:JSON.stringify({status:st})}).then(function(d){if(d.code===200)loadResults();else alert(d.message||'操作失败');});}

// ===== 2.4 AI Skill =====
function loadSkills(){
  var s=document.getElementById('skillSearch').value,t=document.getElementById('skillTypeFilter').value;
  api('/api/skill/list?name='+encodeURIComponent(s)+'&type='+t,{method:'GET'}).then(function(d){if(d.code===200)renderSkillTable(d.data.records||[]);});
}
function renderSkillTable(ss){
  var tb=document.getElementById('skillTable');
  if(!ss||!ss.length){tb.innerHTML='<tr><td colspan="8" class="empty-state"><div class="icon">🤖</div>暂无Skill</td></tr>';return;}
  tb.innerHTML=ss.map(function(s){var typeMap={analyzer:'分析器',fixer:'修复器',reviewer:'审查器'};var typeCls={analyzer:'tag-info',fixer:'tag-success',reviewer:'tag-purple'};return '<tr><td>'+s.id+'</td><td>'+esc(s.name)+'</td><td><span class="tag '+(typeCls[s.type]||'tag-default')+'">'+(typeMap[s.type]||s.type||'-')+'</span></td><td>'+esc(s.provider||'-')+'</td><td><code>'+esc(s.model||'-')+'</code></td><td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+esc(s.description||'-')+'</td><td>'+(s.status===1?'<span class="tag tag-success">启用</span>':'<span class="tag tag-default">禁用</span>')+'</td><td><div class="actions"><button class="btn btn-sm btn-default" onclick="editSkill('+s.id+')">编辑</button><button class="btn btn-sm btn-danger" onclick="delSkill('+s.id+')">删除</button></div></td></tr>';}).join('');
}
function showSkillModal(id){
  currentEditId=id; document.getElementById('modalTitle').textContent=id?'编辑Skill':'添加Skill';
  var body='<div class="form-group"><label>名称</label><input type="text" id="mSkillName" placeholder="请输入名称"></div><div class="form-group"><label>类型</label><select id="mSkillType"><option value="analyzer">分析器</option><option value="fixer">修复器</option><option value="reviewer">审查器</option></select></div><div class="form-group"><label>Provider</label><select id="mSkillProvider"><option value="openai">OpenAI</option><option value="claude">Claude</option><option value="local">本地模型</option></select></div><div class="form-group"><label>模型</label><input type="text" id="mSkillModel" placeholder="如 gpt-4"></div><div class="form-group"><label>描述</label><textarea id="mSkillDesc" placeholder="请输入描述"></textarea></div><div class="form-group"><label>配置(JSON)</label><textarea id="mSkillConfig" placeholder=\'{"temperature":0.7}\' style="font-family:monospace"></textarea></div>';
  document.getElementById('modalBody').innerHTML=body;
  if(id) api('/api/skill/'+id,{method:'GET'}).then(function(d){if(d.code===200){var s=d.data;document.getElementById('mSkillName').value=s.name||'';document.getElementById('mSkillType').value=s.type||'analyzer';document.getElementById('mSkillProvider').value=s.provider||'openai';document.getElementById('mSkillModel').value=s.model||'';document.getElementById('mSkillDesc').value=s.description||'';document.getElementById('mSkillConfig').value=s.config||'';}});
  document.getElementById('modalOverlay').classList.remove('hidden'); modalCallback=saveSkill;
}
function saveSkill(){
  var n=document.getElementById('mSkillName').value,t=document.getElementById('mSkillType').value,p=document.getElementById('mSkillProvider').value,m=document.getElementById('mSkillModel').value,d=document.getElementById('mSkillDesc').value,c=document.getElementById('mSkillConfig').value;
  if(!n){alert('请输入名称');return;}
  var mt=currentEditId?'PUT':'POST',u=currentEditId?'/api/skill/'+currentEditId:'/api/skill';
  api(u,{method:mt,body:JSON.stringify({name:n,type:t,provider:p,model:m,description:d,config:c})}).then(function(d){if(d.code===200){closeModal();loadSkills();}else alert(d.message||'保存失败');});
}
function editSkill(id){showSkillModal(id);}
function delSkill(id){if(!confirm('确定删除？'))return;api('/api/skill/'+id,{method:'DELETE'}).then(function(d){if(d.code===200)loadSkills();else alert(d.message||'删除失败');});}

// ===== 1.2 用户管理 =====
function loadUsers(){
  var s=document.getElementById('userSearch').value,r=document.getElementById('userRoleFilter').value,st=document.getElementById('userStatusFilter').value;
  api('/api/user/list?username='+encodeURIComponent(s)+'&role='+r+'&status='+st,{method:'GET'}).then(function(d){if(d.code===200)renderUserTable(d.data.records||[]);});
}
function renderUserTable(us){
  var tb=document.getElementById('userTable');
  if(!us||!us.length){tb.innerHTML='<tr><td colspan="8" class="empty-state"><div class="icon">👥</div>暂无用户</td></tr>';return;}
  tb.innerHTML=us.map(function(u){return '<tr><td>'+u.id+'</td><td>'+esc(u.username)+'</td><td>'+esc(u.realName||'-')+'</td><td>'+esc(u.email||'-')+'</td><td>'+roleTag(u.role||'user')+'</td><td>'+(u.status===1?'<span class="tag tag-success">启用</span>':'<span class="tag tag-default">禁用</span>')+'</td><td>'+(u.lastLoginTime||'-')+'</td><td><div class="actions"><button class="btn btn-sm btn-default" onclick="editUser('+u.id+')">编辑</button><button class="btn btn-sm '+(u.status===1?'btn-danger':'btn-primary')+'" onclick="toggleUserStatus('+u.id+','+u.status+')">'+(u.status===1?'禁用':'启用')+'</button></div></td></tr>';}).join('');
}
function showUserModal(id){
  currentEditId=id; document.getElementById('modalTitle').textContent=id?'编辑用户':'添加用户';
  var body='<div class="form-group"><label>用户名</label><input type="text" id="mUserName" placeholder="请输入用户名"></div><div class="form-group"><label>姓名</label><input type="text" id="mRealName" placeholder="请输入姓名"></div><div class="form-group"><label>邮箱</label><input type="email" id="mUserEmail" placeholder="请输入邮箱"></div><div class="form-group"><label>角色</label><select id="mUserRole"><option value="admin">管理员</option><option value="user">普通用户</option></select></div>'+(id?'':'<div class="form-group"><label>密码</label><input type="password" id="mUserPwd" placeholder="请输入密码"></div>');
  document.getElementById('modalBody').innerHTML=body;
  if(id) api('/api/user/'+id,{method:'GET'}).then(function(d){if(d.code===200){var u=d.data;document.getElementById('mUserName').value=u.username||'';document.getElementById('mRealName').value=u.realName||'';document.getElementById('mUserEmail').value=u.email||'';document.getElementById('mUserRole').value=u.role||'user';}});
  document.getElementById('modalOverlay').classList.remove('hidden'); modalCallback=saveUser;
}
function saveUser(){
  var n=document.getElementById('mUserName').value,rn=document.getElementById('mRealName').value,e=document.getElementById('mUserEmail').value,r=document.getElementById('mUserRole').value;
  var body={username:n,realName:rn,email:e,role:r};
  var pwdEl=document.getElementById('mUserPwd'); if(pwdEl&&pwdEl.value)body.password=pwdEl.value;
  if(!n){alert('请输入用户名');return;}
  var m=currentEditId?'PUT':'POST',u=currentEditId?'/api/user/'+currentEditId:'/api/user';
  api(u,{method:m,body:JSON.stringify(body)}).then(function(d){if(d.code===200){closeModal();loadUsers();}else alert(d.message||'保存失败');});
}
function editUser(id){showUserModal(id);}
function toggleUserStatus(id,st){api('/api/user/'+id+'/status',{method:'PUT',body:JSON.stringify({status:st===1?0:1})}).then(function(d){if(d.code===200)loadUsers();else alert(d.message||'操作失败');});}

// ===== 3.1 审计日志 =====
function loadAuditLogs(){
  var s=document.getElementById('auditSearch').value,t=document.getElementById('auditTypeFilter').value;
  api('/api/audit/list?username='+encodeURIComponent(s)+'&operationType='+t,{method:'GET'}).then(function(d){if(d.code===200)renderAuditTable(d.data.records||[]);});
}
function renderAuditTable(ls){
  var tb=document.getElementById('auditTable');
  if(!ls||!ls.length){tb.innerHTML='<tr><td colspan="7" class="empty-state"><div class="icon">📜</div>暂无日志</td></tr>';return;}
  tb.innerHTML=ls.map(function(l){return '<tr><td>'+l.id+'</td><td><span class="tag tag-info">'+esc(l.operationType||'-')+'</span></td><td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+esc(l.operation||'-')+'</td><td>'+esc(l.username||'-')+'</td><td>'+esc(l.ipAddress||'-')+'</td><td>'+(l.success?'<span class="tag tag-success">成功</span>':'<span class="tag tag-danger">失败</span>')+'</td><td>'+(l.createTime||'-')+'</td></tr>';}).join('');
}
function exportAudit(){alert('导出功能开发中');}

// ===== 3.2 系统设置 =====
function loadSettings(){
  var cfg=JSON.parse(localStorage.getItem('sysSettings')||'{}');
  if(cfg.provider)document.getElementById('cfgProvider').value=cfg.provider;
  if(cfg.model)document.getElementById('cfgModel').value=cfg.model;
  if(cfg.endpoint)document.getElementById('cfgEndpoint').value=cfg.endpoint;
  if(cfg.temp)document.getElementById('cfgTemp').value=cfg.temp;
  if(cfg.email)document.getElementById('cfgEmail').checked=true;
  if(cfg.dingTalk)document.getElementById('cfgDingTalk').checked=true;
  if(cfg.weChat)document.getElementById('cfgWeChat').checked=true;
  if(cfg.webhook)document.getElementById('cfgWebhook').value=cfg.webhook;
  if(cfg.session)document.getElementById('cfgSession').value=cfg.session;
  if(cfg.maxAttempt)document.getElementById('cfgMaxAttempt').value=cfg.maxAttempt;
  if(cfg.pwdLen)document.getElementById('cfgPwdLen').value=cfg.pwdLen;
  if(cfg.tokenTTL)document.getElementById('cfgTokenTTL').value=cfg.tokenTTL;
}
function saveSettings(){
  var cfg={provider:document.getElementById('cfgProvider').value,model:document.getElementById('cfgModel').value,endpoint:document.getElementById('cfgEndpoint').value,temp:document.getElementById('cfgTemp').value,email:document.getElementById('cfgEmail').checked,dingTalk:document.getElementById('cfgDingTalk').checked,weChat:document.getElementById('cfgWeChat').checked,webhook:document.getElementById('cfgWebhook').value,session:document.getElementById('cfgSession').value,maxAttempt:document.getElementById('cfgMaxAttempt').value,pwdLen:document.getElementById('cfgPwdLen').value,tokenTTL:document.getElementById('cfgTokenTTL').value};
  localStorage.setItem('sysSettings',JSON.stringify(cfg));
}

// ===== 模态框 =====
function closeModal(){document.getElementById('modalOverlay').classList.add('hidden');currentEditId=null;modalCallback=null;}
function confirmModal(){if(modalCallback)modalCallback();}
function closeDetail(){document.getElementById('detailOverlay').classList.add('hidden');}

// ===== 初始化 =====
document.getElementById('loginForm').addEventListener('submit',handleLogin);
if(token){showApp();loadDashboardData();}
</script>
</body>
</html>
